{
  "ConnectionStrings": {
    "ChatDb": "Server=(localdb)\\MSSQLLocalDB;Database=MoneybaseChat;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "ChatOptions": {
    "OfficeHoursStart": "08:00",
    "OfficeHoursEnd": "20:00",
    "MaxConcurrentPerAgent": 10,
    "QueueMultiplier": 1.5,
    "PollIntervalSeconds": 1,
    "MaxMissedPolls": 3
  },
  "TeamSchedules": {
    "Teams": [
      { "TeamName": "Team A", "StartTime": "08:00", "EndTime": "16:00" },
      { "TeamName": "Team B", "StartTime": "16:00", "EndTime": "00:00" },
      { "TeamName": "Team C", "StartTime": "00:00", "EndTime": "08:00" },
      { "TeamName": "Overflow", "StartTime": "08:00", "EndTime": "20:00" }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
